{
  "agent": "tau_bench_airline",
  "obligations": [
    {
      "id": "obl-obtain-user-id",
      "text": "obtain the user id from the user before booking a flight",
      "category": "policy_compliance"
    },
    {
      "id": "obl-obtain-reservation-id",
      "text": "obtain the user id and reservation id before modifying or canceling a flight",
      "category": "policy_compliance"
    },
    {
      "id": "obl-confirm-cancellation-reason",
      "text": "obtain the reason for cancellation before processing",
      "category": "policy_compliance"
    },
    {
      "id": "obl-confirm-checked-bags",
      "text": "do not add checked bags that the user does not need",
      "category": "policy_compliance"
    },
    {
      "id": "obl-confirm-travel-insurance",
      "text": "ask if the user wants to buy travel insurance",
      "category": "policy_compliance"
    },
    {
      "id": "obl-confirm-compensation-eligibility",
      "text": "confirm the facts before offering compensation",
      "category": "policy_compliance"
    },
    {
      "id": "obl-deny-invalid-requests",
      "text": "deny user requests that are against this policy",
      "category": "policy_compliance"
    }
  ],
  "forbidden_behaviors": [
    {
      "id": "fb-provide-unverified-info",
      "text": "do not provide any information, knowledge, or procedures not provided by the user or available tools",
      "category": "information_grounding"
    },
    {
      "id": "fb-provide-subjective-recommendations",
      "text": "do not give subjective recommendations or comments",
      "category": "information_grounding"
    },
    {
      "id": "fb-make-multiple-tool-calls",
      "text": "do not make a tool call and respond to the user simultaneously",
      "category": "scope_adherence"
    },
    {
      "id": "fb-modify-basic-economy",
      "text": "do not modify basic economy flights",
      "category": "policy_compliance"
    },
    {
      "id": "fb-modify-passenger-count",
      "text": "do not modify the number of passengers",
      "category": "policy_compliance"
    },
    {
      "id": "fb-add-insurance-after-booking",
      "text": "do not add insurance after initial booking",
      "category": "policy_compliance"
    },
    {
      "id": "fb-offer-compensation-proactively",
      "text": "do not proactively offer compensation unless the user explicitly asks for one",
      "category": "policy_compliance"
    },
    {
      "id": "fb-compensate-regular-members",
      "text": "do not compensate if the user is a regular member and has no travel insurance and flies (basic) economy",
      "category": "policy_compliance"
    }
  ],
  "tool_sequences": [
    {
      "id": "ts-transfer-to-human",
      "target_tool": "transfer_to_human_agents",
      "prerequisite_tools": [
        "get_user_details"
      ],
      "category": "tool_sequence_correctness"
    },
    {
      "id": "ts-book-reservation",
      "target_tool": "book_reservation",
      "prerequisite_tools": [
        "get_user_details"
      ],
      "category": "tool_sequence_correctness"
    },
    {
      "id": "ts-cancel-reservation",
      "target_tool": "cancel_reservation",
      "prerequisite_tools": [
        "get_user_details",
        "get_reservation_details"
      ],
      "category": "tool_sequence_correctness"
    },
    {
      "id": "ts-update-reservation-baggages",
      "target_tool": "update_reservation_baggages",
      "prerequisite_tools": [
        "get_user_details",
        "get_reservation_details"
      ],
      "category": "tool_sequence_correctness"
    },
    {
      "id": "ts-update-reservation-flights",
      "target_tool": "update_reservation_flights",
      "prerequisite_tools": [
        "get_user_details",
        "get_reservation_details"
      ],
      "category": "tool_sequence_correctness"
    },
    {
      "id": "ts-update-reservation-passengers",
      "target_tool": "update_reservation_passengers",
      "prerequisite_tools": [
        "get_user_details",
        "get_reservation_details"
      ],
      "category": "tool_sequence_correctness"
    }
  ]
