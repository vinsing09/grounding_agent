{
  "agent": "tau_bench_airline",
  "obligations": [
    {
      "id": "obl-obtain-user-id",
      "text": "obtain the user id before booking a flight",
      "category": "policy_compliance"
    },
    {
      "id": "obl-obtain-trip-details",
      "text": "ask for the trip type, origin, and destination before booking a flight",
      "category": "policy_compliance"
    },
    {
      "id": "obl-obtain-confirmation",
      "text": "list the action details and obtain explicit user confirmation before updating the booking database",
      "category": "confirmation_discipline"
    },
    {
      "id": "obl-deny-requests",
      "text": "deny user requests that are against the policy",
      "category": "policy_compliance"
    },
    {
      "id": "obl-obtain-reservation-details",
      "text": "obtain the user id and reservation id before modifying a flight",
      "category": "policy_compliance"
    },
    {
      "id": "obl-obtain-cancellation-details",
      "text": "obtain the user id, reservation id, and reason for cancellation before cancelling a flight",
      "category": "policy_compliance"
    },
    {
      "id": "obl-validate-flight-modification",
      "text": "ensure that basic economy flights cannot be modified before calling the API",
      "category": "tool_argument_correctness"
    },
    {
      "id": "obl-validate-cancellation-conditions",
      "text": "ensure that cancellation conditions are met before calling the API",
      "category": "tool_argument_correctness"
    },
    {
      "id": "obl-ask-for-insurance",
      "text": "ask if the user wants to buy travel insurance",
      "category": "policy_compliance"
    },
    {
      "id": "obl-validate-payment-methods",
      "text": "ensure that payment methods are already in user profile for safety reasons",
      "category": "tool_argument_correctness"
    }
  ],
  "forbidden_behaviors": [
    {
      "id": "fb-provide-unverified-info",
      "text": "do not provide any information, knowledge, or procedures not provided by the user or available tools",
      "category": "information_grounding"
    },
    {
      "id": "fb-simultaneous-tool-call",
      "text": "do not respond to the user while making a tool call",
      "category": "scope_adherence"
    },
    {
      "id": "fb-modify-basic-economy",
      "text": "do not modify basic economy flights",
      "category": "policy_compliance"
    },
    {
      "id": "fb-cancel-flights-not-eligible",
      "text": "do not cancel flights if the conditions are not met",
      "category": "policy_compliance"
    },
    {
      "id": "fb-add-insurance-after-booking",
      "text": "do not add insurance after initial booking",
      "category": "policy_compliance"
    },
    {
      "id": "fb-modify-passenger-count",
      "text": "do not modify the number of passengers",
      "category": "policy_compliance"
    },
    {
      "id": "fb-proactively-offer-compensation",
      "text": "do not proactively offer compensation unless the user complains",
      "category": "policy_compliance"
    }
  ],
  "tool_sequences": [
    {
      "id": "ts-book-reservation",
      "target_tool": "book_reservation",
      "prerequisite_tools": [
        "get_user_details"
      ],
      "category": "tool_sequence_correctness"
    },
    {
      "id": "ts-update-reservation_flights",
      "target_tool": "update_reservation_flights",
      "prerequisite_tools": [
        "get_user_details",
        "get_reservation_details"
      ],
      "category": "tool_sequence_correctness"
    },
    {
      "id": "ts-cancel_reservation",
      "target_tool": "cancel_reservation",
      "prerequisite_tools": [
        "get_user_details",
        "get_reservation_details"
      ],
      "category": "tool_sequence_correctness"
    }
  ]
}
